backend/db/*.db-shm
backend/db/*.db-wal

# Frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/

# ─── Environment variables ────────────────────────────────────────────────────
.env
.env.local
.env.production
backend/.env
frontend/.env
frontend/.env.local
frontend/.env.production

# ─── Build output ─────────────────────────────────────────────────────────────
dist/
build/

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
logs/

# ─── OS generated files ───────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

