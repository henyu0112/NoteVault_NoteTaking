# ─── Frontend Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local for local development (optional)
# For production, set these in your hosting platform (Vercel, Netlify, etc.)

# Base URL of the backend API (include /api suffix)
# Leave blank to use the Vite dev proxy (/api → localhost:3001)
# Production example: VITE_API_URL=https://your-backend.up.railway.app/api
VITE_API_URL=
